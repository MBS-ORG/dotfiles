[user]
    name = mbs
    email = mbs@localhost
[alias]
    s = status
    l = log --oneline --graph
    a = add
    c = commit
    d = diff
    co = checkout
    cb = checkout -b
    p = push
    pl = pull --rebase
    amend = commit --amend
    undo = reset HEAD~1 --mixed
[core]
    pager = delta
[interactive]
    diffFilter = delta --color-only
[delta]
    navigate = true
    light = false
    side-by-side = true
[merge]
    conflictstyle = zdiff3
[pull]
    rebase = true
[push]
    autoSetupRemote = true
[init]
    defaultBranch = main
[includeIf "gitdir:~/.config/dotfiles/"]
    path = .gitconfig.local
