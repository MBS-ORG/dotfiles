# Secrets — never commit these
gh/.config/gh/hosts.yml
agent/.agent/*.key
agent/.agent/*.pem
ssh/.ssh/id_*
ssh/.ssh/known_hosts
ssh/.ssh/authorized_keys

# Ephemeral
*.log
*.tmp
.DS_Store
node_modules/
__pycache__/
*.pyc

# AI session artifacts (regenerated per session)
.omo/evidence/
.omo/plans/
.omo/run-continuation/

# Stale source archives (already consolidated)
*.zip
Staging/
